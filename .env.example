PORT=5001
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/chatting-app

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Comma-separated allowed frontend origins (CORS + Socket.IO)
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000

UPLOAD_DIR=uploads

# AWS S3 (required for image uploads)
# AWS_REGION must match the bucket region (backet-for-confaero is us-east-2)

# IAM user needs at least: s3:PutObject, s3:GetObject on arn:aws:s3:::BUCKET/*

# Upstash Redis (optional — app works without it)
# Use the URL only — not the redis-cli command from Upstash
REDIS_URL=rediss://default:password@ultimate-grizzly-79618.upstash.io:6379
REDIS_ENABLED=true

# Socket.IO multi-instance fan-out (requires Redis; disable with SOCKET_REDIS_ADAPTER=false)
SOCKET_REDIS_ADAPTER=true

# MongoDB connection pool (raise per replica: replicas × maxPoolSize ≤ Atlas limit)
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=5

# ZEGOCLOUD (audio calls) — App ID must be numeric from the console
ZEGOCLOUD_APP_ID=0
ZEGOCLOUD_APP_SIGN=
ZEGOCLOUD_SERVER_SECRET=
# WebSocket server from your project region (see ZEGOCLOUD console)
ZEGOCLOUD_SERVER_URL=wss://webliveroom-api.zego.im/ws
