PORT=5001
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/chatting-app

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Comma-separated allowed frontend origins (CORS + Socket.IO)
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000,https://easy-connectify.vercel.app

# Public frontend URL — used to build links in emails (password reset)
FRONTEND_URL=http://localhost:3000

# --- Mail (password reset) — pick ONE approach (no SendGrid needed) ---
#
# OPTION A — Google Workspace (recommended): noreply@yourdomain.com via Gmail SMTP
#   1. Google Workspace → verify yourdomain.com (adds SPF/DKIM automatically)
#   2. Create mailbox noreply@yourdomain.com, enable 2FA, create App Password
MAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
APP_USER_EMAIL=noreply@yourdomain.com
APP_PASSWORD=your-google-app-password
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=Connectify
FRONTEND_URL=https://easy-connectify.vercel.app
#
# OPTION B — Amazon SES (uses AWS keys below; verify domain in SES console + DKIM DNS)
# MAIL_PROVIDER=ses
# MAIL_FROM=noreply@yourdomain.com
# MAIL_FROM_NAME=Connectify
# FRONTEND_URL=https://easy-connectify.vercel.app
# IAM: ses:SendEmail, ses:ListIdentities. Request "production access" to leave sandbox.
#
# Personal @gmail.com works for dev only — almost always lands in spam in production.

UPLOAD_DIR=uploads

# AWS S3 (required — app will not start without these)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_BUCKET_NAME=your-bucket-name

# IAM user needs at least: s3:PutObject, s3:GetObject on arn:aws:s3:::BUCKET/*

# Upstash Redis (optional — app works without it)
# Use the URL only — not the redis-cli command from Upstash
REDIS_URL=rediss://default:password@ultimate-grizzly-79618.upstash.io:6379
REDIS_ENABLED=true

# Socket.IO multi-instance fan-out (requires Redis; disable with SOCKET_REDIS_ADAPTER=false)
SOCKET_REDIS_ADAPTER=true

# MongoDB connection pool (raise per replica: replicas × maxPoolSize ≤ Atlas limit)
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=5

# ZEGOCLOUD (audio calls) — App ID must be numeric from the console
ZEGOCLOUD_APP_ID=0
ZEGOCLOUD_APP_SIGN=
# 32-character Server Secret from console (NOT App Sign). Compare secretFingerprint via /health across machines.
ZEGOCLOUD_SERVER_SECRET=
# Set to false to mint a general token (empty payload) for debugging only
ZEGO_TOKEN_STRICT=true
# WebSocket server from your project region (see ZEGOCLOUD console)
ZEGOCLOUD_SERVER_URL=wss://webliveroom-api.zego.im/ws
